{
  "manifest_version": 3,
  "name": "AI Chat Enter Option",
  "version": "1.3",
  "description": "Customize Enter key behavior on gemini.google.com, chatgpt.com and claude.ai using a slider.",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon512x512.png",
    "32": "icons/icon512x512.png",
    "48": "icons/icon512x512.png",
    "128": "icons/icon512x512.png",
    "512": "icons/icon512x512.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon512x512.png",
      "32": "icons/icon512x512.png",
      "48": "icons/icon512x512.png",
      "128": "icons/icon512x512.png",
      "512": "icons/icon512x512.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://*.claude.ai/*",
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
