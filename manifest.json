{
  "manifest_version": 3,
  "name": "AI Chat Enter Option",
  "version": "1.3",
  "description": "Customize Enter key behavior on gemini.google.com, chatgpt.com and claude.ai using a slider.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_icon": {
      "512": "icons/icon512x512.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://chatgpt.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
